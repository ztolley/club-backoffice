# Block execution of PHP-like files in publicly linked upload storage.
<FilesMatch "(?i)\.(php[0-9]?|phtml?|phar|pht|phtm)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order Deny,Allow
        Deny from all
    </IfModule>
</FilesMatch>
